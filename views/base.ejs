<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="VUU Transport - The premium bus and taxi booking platform for Rwanda.">
    <!-- Using Bootstrap for quick styling since Tailwind isn't preconfigured via Vite now -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-light">
    
    <nav class="navbar navbar-expand-lg navbar-dark bg-vuu-blue shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
          <span class="fs-4">🚐 VUU Transport</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExample">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarsExample">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="/book">Book Ride</a></li>
            <li class="nav-item"><a class="nav-link" href="/routes">Routes & Prices</a></li>
          </ul>
          <div class="d-flex gap-2">
            <a href="/login" class="btn btn-outline-light">Login</a>
            <a href="/register" class="btn btn-vuu-green">Sign Up</a>
            
            <select class="form-select w-auto ms-2 bg-dark text-white border-0">
                <option value="en">English</option>
                <option value="rw">Kinyarwanda</option>
            </select>
          </div>
        </div>
      </div>
    </nav>

    <main class="container my-5" style="min-height: 65vh;">
        <%- yield %>
    </main>

    <footer class="bg-vuu-blue text-white py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-1">&copy; 2026 VUU Transport Rwanda. All rights reserved.</p>
            <p class="text-white-50 small">Kigali, Rwanda | +250 788 000 000 | info@vuu.rw</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/main.js"></script>
</body>
</html>
