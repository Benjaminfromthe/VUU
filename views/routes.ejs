<%- include('header') %>

  <div class="row mb-4">
    <div class="col-12 text-center">
      <h2 class="text-vuu-blue fw-bold">Available Routes & Pricing</h2>
      <p class="text-secondary">Transparent pricing across Rwanda. No hidden fees.</p>
    </div>
  </div>

  <div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle text-center mb-0">
      <thead class="table-light">
        <tr>
          <th class="py-3 text-secondary">From</th>
          <th class="py-3 text-secondary">To</th>
          <th class="py-3 text-secondary">Estimated Time</th>
          <th class="py-3 text-secondary">Price (RWF)</th>
        </tr>
      </thead>
      <tbody>
        <% routes.forEach(route => { %>
          <tr>
            <td class="py-3 fw-bold text-dark"><%= route.start_loc %></td>
            <td class="py-3 fw-bold text-dark"><%= route.end_loc %></td>
            <td class="py-3 text-muted">
              <span class="badge bg-light text-dark border"><%= route.duration %></span>
            </td>
            <td class="py-3 text-success fw-bold"><%= route.price %> RWF</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  
  <div class="text-center mt-4">
    <a href="/book" class="btn btn-vuu-green px-5 py-2 fw-semibold shadow-sm">Book Your Seat Now</a>
  </div>
<%- include('footer') %>
